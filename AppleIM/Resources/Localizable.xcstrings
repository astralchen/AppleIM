    "account.delete.confirm.message" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيؤدي هذا إلى حذف قاعدة البيانات المحلية وفهرس البحث وملفات الوسائط والذاكرة المؤقتة ومفتاح قاعدة البيانات للحساب الحالي على هذا الجهاز. لن تتأثر الحسابات الأخرى."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This deletes the current account's local database, search index, media files, cache, and database key from this device. Other accounts are not affected."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这会删除当前账号在本设备上的本地数据库、搜索索引、媒体文件、缓存和数据库密钥。其他账号不受影响。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這會刪除目前帳號在本裝置上的本機資料庫、搜尋索引、媒體檔案、快取和資料庫金鑰。其他帳號不受影響。"
          }
        }
      }
    },
