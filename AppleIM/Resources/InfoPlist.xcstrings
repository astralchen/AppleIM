    "NSMicrophoneUsageDescription" : {
      "comment" : "Privacy - Microphone Usage Description",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحتاج ChatBridge إلى إذن الميكروفون حتى تتمكن من تسجيل الرسائل الصوتية."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChatBridge needs microphone access so you can record voice messages."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChatBridge 需要访问麦克风，以便你录制语音消息。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChatBridge 需要取用麥克風，以便你錄製語音訊息。"
          }
        }
      }
    },
    "NSPhotoLibraryUsageDescription" : {
      "comment" : "Privacy - Photo Library Usage Description",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحتاج ChatBridge إلى إذن مكتبة الصور حتى تتمكن من اختيار الصور لإرسالها في المحادثات."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChatBridge needs photo library access so you can choose images to send in chats."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChatBridge 需要访问照片图库，以便你选择图片发送到聊天中。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChatBridge 需要取用照片圖庫，以便你選擇圖片傳送到聊天中。"
          }
        }
      }
    }
  },
  "version" : "1.0"
}